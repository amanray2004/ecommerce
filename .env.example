# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ecommerce
KEYCLOAK_ISSUER=http://localhost:8080/realms/ecommerce
KEYCLOAK_AUDIENCE=fastapi-backend
KEYCLOAK_CLIENT_ID=fastapi-backend
# Optional if you want static key mode instead of JWKS
# KEYCLOAK_PUBLIC_KEY=

FIREBASE_BUCKET=
FIREBASE_CREDENTIALS_PATH=

SEED_ROLES_ON_STARTUP=true
RUN_STARTUP_TASKS=true
AUTO_CREATE_TABLES=false

# Frontend (copy to frontend/.env as well)
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ecommerce
VITE_KEYCLOAK_CLIENT_ID=fastapi-backend
VITE_DEFAULT_TENANT=nike
